{
  "name": "seth-solana-bridge-relayer",
  "version": "1.0.0",
  "description": "Cross-chain bridge relayer for Seth <-> Solana and BSC <-> Solana",
  "main": "relayer.js",
  "scripts": {
    "start": "node relayer.js",
    "start:bsc": "node bsc-relayer.js",
    "start:bsc:v2": "node bsc-relayer-v2.js",
    "dev": "nodemon relayer.js",
    "dev:bsc": "nodemon bsc-relayer.js",
    "dev:bsc:v2": "nodemon bsc-relayer-v2.js",
    "db:init": "mysql -u root bridge_relayer < db/init.sql",
    "db:init:bsc": "mysql -u root bridge_relayer_bsc < db/init.sql",
    "test": "echo \"No tests yet\" && exit 0",
    "test:bsc": "node testBscClient.js",
    "test:bsc:load": "node -e \"const BscClient = require('./bscClient'); console.log('BscClient loaded successfully');\"",
    "verify:seth": "node verify-seth-bridge.js"
  },
  "keywords": [
    "blockchain",
    "bridge",
    "relayer",
    "solana",
    "seth",
    "cross-chain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.87.0",
    "axios": "^1.6.0",
    "bs58": "^5.0.0",
    "buffer": "^6.0.3",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "https-proxy-agent": "^7.0.6",
    "keccak": "^3.0.4",
    "mysql2": "^3.14.5",
    "secp256k1": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
