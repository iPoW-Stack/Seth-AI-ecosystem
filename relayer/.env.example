# ==================== Solana 配置 ====================
# Solana RPC URL (推荐使用私有RPC如 QuickNode, Helius 等)
SOLANA_RPC_URL=https://api.devnet.solana.com

# 如需通过 HTTP 代理访问 Solana RPC，可配置（可选）
# 例如: http://127.0.0.1:7890
# SOLANA_HTTP_PROXY=http://127.0.0.1:7890

# Solana Bridge Program ID (已部署)
SOLANA_PROGRAM_ID=125eQs1s3SNxd5KFRpAJ6JvtVpD4tRYw6fWKomibQ8tc

# Solana 轮询间隔 (毫秒)
SOLANA_POLL_INTERVAL=5000

# ==================== Seth 链配置 ====================
# Seth 链节点地址
SETH_HOST=35.197.170.240
SETH_PORT=23001

# 如需通过 HTTP 代理访问 Seth 节点，可配置（可选）
# 例如: http://127.0.0.1:7890
# SETH_HTTP_PROXY=http://127.0.0.1:7890

# Seth Bridge 合约地址 (部署后更新)
SETH_BRIDGE_ADDRESS=0x65e97821f80431290d51ffb5ee08144296362a3d00000

# Relayer 私钥 (请妥善保管，不要提交到代码库)
RELAYER_PRIVATE_KEY=0x4b6525236a2029ab54e2c6162c483133c1af7d38bd960f85b1f485c31e696b7b

# ==================== 数据库配置 ====================
# PostgreSQL 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bridge_relayer
DB_USER=postgres
DB_PASSWORD=xia123456

# 数据库最大连接数
DB_MAX_CONNECTIONS=10

# ==================== Relayer 配置 ====================
# 最大重试次数
MAX_RETRIES=5

# 重试间隔 (毫秒)
RETRY_INTERVAL=60000

# 批处理大小
BATCH_SIZE=10